# GovLens Environment Configuration
# Copy to .env and fill in values

# JWT Secret — minimum 64 characters, random string
JWT_SECRET=changeThisToALongRandomStringInProductionMinimum64CharsLong

# OpenAI API Key (optional — insight engine degrades gracefully without it)
OPENAI_API_KEY=

# Database (defaults work with docker-compose)
DB_USERNAME=govlens
DB_PASSWORD=govlens
